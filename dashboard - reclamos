<footer>
  <p>Datos correspondientes al período enero–abril 2026 · Actualización: <span id="hoy2"></span> · Generado con Dashboard PRO</p>
  <div class="footer-logo" id="footer-logo">Gestión Operativa · Sistema de Reclamos</div>
</footer>

<script>
// ════════════════════════════════════════
//  DATA
// ════════════════════════════════════════
const DATA = {
  medidor: {
    titulo: 'Pérdida Caja del Medidor', badge: '🔧 Pérdida · Caja del Medidor',
    total: 2143, resueltos: 1034, pendientes: 1109,
    zonas: [
      { nombre:'Zona 12',        cant:256 },{ nombre:'Zona 15',        cant:203 },
      { nombre:'Zona 14',        cant:169 },{ nombre:'Zona 26 F.M.',   cant:126 },
      { nombre:'Zona 13',        cant:103 },{ nombre:'Zona 28 Luque',  cant: 72 },
      { nombre:'Zona 29 MRA',    cant: 63 },{ nombre:'Zona 10',        cant: 55 },
      { nombre:'Zona 11',        cant: 39 },{ nombre:'Zona 18 V.Elisa',cant:  7 },
      { nombre:'Zona 37 S.A.',   cant:  6 },{ nombre:'Zona 27 S.L.',   cant:  6 },
      { nombre:'Zona 16 Limpio', cant:  5 },
    ]
  },
  agua: {
    titulo: 'Falta de Agua y Poca Presión', badge: '💧 Falta de Agua / Poca Presión',
    total: 0, resueltos: 0, pendientes: 0,
    zonas: [
      { nombre:'Zona 10', cant:0 },{ nombre:'Zona 11', cant:0 },
      { nombre:'Zona 12', cant:0 },{ nombre:'Zona 13', cant:0 },
      { nombre:'Zona 14', cant:0 },{ nombre:'Zona 15', cant:0 },
      { nombre:'Zona 16 Limpio',  cant:0 },{ nombre:'Zona 18 V.Elisa', cant:0 },
      { nombre:'Zona 26 F.M.',    cant:0 },{ nombre:'Zona 27 S.L.',    cant:0 },
      { nombre:'Zona 28 Luque',   cant:0 },{ nombre:'Zona 29 MRA',     cant:0 },
      { nombre:'Zona 37 S.A.',    cant:0 },
    ]
  }
};

let currentMode = 'medidor';

function classify(c) {
  if (c > 150) return { label:'🔴 Crítico',    cls:'chip-red',    bar:'fill-red',    chart:'c-red',    color:'var(--red)'    };
  if (c >= 41) return { label:'🟡 Alto/Medio', cls:'chip-yellow', bar:'fill-yellow', chart:'c-yellow', color:'var(--yellow)' };
  return             { label:'🟢 Bajo',        cls:'chip-green',  bar:'fill-green',  chart:'c-green',  color:'var(--green)'  };
}

// ════════════════════════════════════════
//  RENDER
// ════════════════════════════════════════
function renderDashboard() {
  const d = DATA[currentMode];
  const zonas = [...d.zonas].sort((a,b) => b.cant - a.cant);
  const MAX = Math.max(...zonas.map(z => z.cant), 1);

  document.getElementById('title-span').textContent = d.titulo;
  document.getElementById('badge-txt').textContent  = d.badge;

  const pctRes = d.total ? Math.round(d.resueltos  / d.total * 100) : 0;
  const pctPen = d.total ? Math.round(d.pendientes / d.total * 100) : 0;

  document.getElementById('kpi-total').textContent      = d.total.toLocaleString('es-PY');
  document.getElementById('kpi-resueltos').textContent  = d.resueltos.toLocaleString('es-PY');
  document.getElementById('kpi-pendientes').textContent = d.pendientes.toLocaleString('es-PY');
  document.getElementById('kpi-efect').textContent      = pctRes + '%';
  document.getElementById('kpi-res-sub').textContent    = pctRes + '% del total resueltos';
  document.getElementById('kpi-pen-sub').textContent    = pctPen + '% del total en curso';
  document.getElementById('bar-res').style.width        = pctRes + '%';
  document.getElementById('bar-pen').style.width        = pctPen + '%';
  document.getElementById('bar-efect').style.width      = pctRes + '%';

  // Semáforo global
  const criticas = zonas.filter(z => z.cant > 150).length;
  const altas    = zonas.filter(z => z.cant >= 41 && z.cant <= 150).length;
  let lvl = 'green', msg = 'Operación Normal';
  if (criticas > 0)    { lvl='red';    msg='Crítico — Backlog Elevado'; }
  else if (altas > 2)  { lvl='yellow'; msg='Alto — Atención Requerida'; }
  document.getElementById('sg-dot').className  = 'sg-dot '  + lvl;
  document.getElementById('sg-text').className = 'sg-text ' + lvl;
  document.getElementById('sg-text').textContent = msg;
  document.getElementById('sg-desc').textContent =
    criticas + ' zona(s) críticas · ' + pctPen + '% pendiente de resolución';

  // Tabla
  const tbody = document.getElementById('tabla-zonas');
  tbody.innerHTML = '';
  zonas.forEach((z, i) => {
    const s   = classify(z.cant);
    const pct = Math.round((z.cant / MAX) * 100);
    const tr  = document.createElement('tr');
    tr.innerHTML = `
      <td class="rank">${i+1}</td>
      <td class="zona-name">${z.nombre}</td>
      <td class="cant" style="color:${s.color}">${z.cant}</td>
      <td class="status"><span class="chip ${s.cls}">${s.label}</span></td>
      <td class="bar-wrap"><div class="mini-bar"><div class="mini-bar-fill ${s.bar}" style="width:${pct}%"></div></div></td>
    `;
    tbody.appendChild(tr);
  });
  document.getElementById('panel-count').textContent = zonas.length + ' zonas activas';

  // Gráfico
  const chart = document.getElementById('bar-chart');
  chart.innerHTML = '';
  zonas.forEach(z => {
    const s   = classify(z.cant);
    const pct = Math.round((z.cant / MAX) * 100);
    const row = document.createElement('div');
    row.className = 'bar-row';
    row.innerHTML = `
      <div class="bar-zona">${z.nombre.replace('Zona ','Z.')}</div>
      <div class="bar-track">
        <div class="bar-fill ${s.chart}" style="width:0%" data-w="${pct}%">${z.cant}</div>
      </div>
    `;
    chart.appendChild(row);
  });
  setTimeout(() => {
    document.querySelectorAll('.bar-fill[data-w]').forEach(el => { el.style.width = el.dataset.w; });
  }, 80);
}

// ════════════════════════════════════════
//  EDIT
// ════════════════════════════════════════
function buildEditInputs() {
  const d = DATA[currentMode];
  document.getElementById('inp-total').value      = d.total;
  document.getElementById('inp-resueltos').value  = d.resueltos;
  document.getElementById('inp-pendientes').value = d.pendientes;
  const grid = document.getElementById('zone-edit-grid');
  grid.innerHTML = '';
  d.zonas.forEach((z, i) => {
    const row = document.createElement('div');
    row.className = 'zone-edit-row';
    row.innerHTML = `<label title="${z.nombre}">${z.nombre}</label><input type="number" min="0" data-idx="${i}" value="${z.cant}">`;
    grid.appendChild(row);
  });
}

function applyEdits() {
  const d = DATA[currentMode];
  d.total      = parseInt(document.getElementById('inp-total').value)      || 0;
  d.resueltos  = parseInt(document.getElementById('inp-resueltos').value)  || 0;
  d.pendientes = parseInt(document.getElementById('inp-pendientes').value) || 0;
  document.querySelectorAll('#zone-edit-grid input[data-idx]').forEach(inp => {
    d.zonas[parseInt(inp.dataset.idx)].cant = parseInt(inp.value) || 0;
  });
  renderDashboard();
}

function toggleEdit() {
  const body  = document.getElementById('edit-body');
  const arrow = document.getElementById('edit-arrow');
  const open  = body.classList.toggle('open');
  arrow.classList.toggle('open', open);
  if (open) buildEditInputs();
}

// ════════════════════════════════════════
//  MODE SWITCH
// ════════════════════════════════════════
function setMode(mode) {
  currentMode = mode;
  document.body.className = 'mode-' + mode;
  document.getElementById('btn-medidor').classList.toggle('active', mode === 'medidor');
  document.getElementById('btn-agua').classList.toggle('active',    mode === 'agua');
  buildEditInputs();
  renderDashboard();
}

// ════════════════════════════════════════
//  GENERAR PDF
// ════════════════════════════════════════
function generarPDF() {
  // Asegurar que las barras estén al ancho correcto antes de imprimir
  document.querySelectorAll('.bar-fill[data-w]').forEach(el => { el.style.width = el.dataset.w; });

  // Título del documento = tipo de reclamo + fecha
  const d    = DATA[currentMode];
  const hoy  = new Date().toLocaleDateString('es-PY', { day:'2-digit', month:'long', year:'numeric' });
  const prev = document.title;
  document.title = `Dashboard Reclamos — ${d.titulo} — ${hoy}`;

  window.print();

  // Restaurar título original
  setTimeout(() => { document.title = prev; }, 1000);
}

// ════════════════════════════════════════
//  INIT
// ════════════════════════════════════════
const now = new Date();
const fmt = now.toLocaleDateString('es-PY', { day:'2-digit', month:'long', year:'numeric' });
document.getElementById('fecha').textContent = fmt;
document.getElementById('hoy2').textContent  = fmt;
renderDashboard();
</script>

</body>
