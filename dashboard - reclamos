<!-- ═══ CONTENT GRID ══════════════════════════════════ -->

<div class="content-grid">
  <div class="panel">
    <div class="panel-header">
      <span class="panel-title">📍 Ranking por Zona — Tabla Inteligente</span>
      <span class="panel-count" id="panel-count">13 zonas activas</span>
    </div>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Zona</th>
          <th style="text-align:center">Reclamos</th>
          <th style="text-align:center">Estado</th>
          <th>Volumen</th>
        </tr>
      </thead>
